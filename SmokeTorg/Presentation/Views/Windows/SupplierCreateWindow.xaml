<Window x:Class="SmokeTorg.Presentation.Views.Windows.SupplierCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додати постачальника"
        Width="760"
        Height="470"
        MinWidth="700"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="#F7F8FA">
    <Window.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#344054"/>
        </Style>

        <Style x:Key="InputErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Foreground" Value="#D92D20"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource AppTextBoxStyle}">
            <Setter Property="Validation.ErrorTemplate" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#D92D20"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,12">
            <TextBlock Text="Новий постачальник" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Поля з * — обов'язкові" Margin="0,6,0,0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                    <TextBlock Text="Назва постачальника*" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <TextBox x:Name="NameTextBox" Style="{StaticResource FormTextBoxStyle}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                        <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#98A2B3" FontSize="12" IsHitTestVisible="False" Text="Напр.: ТОВ &#39;Постач-Груп&#39;">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=NameTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=NameTextBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding (Validation.Errors), ElementName=NameTextBox}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource InputErrorTextStyle}" Text="{Binding ErrorContent}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,12">
                    <TextBlock Text="Телефон" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <TextBox x:Name="PhoneTextBox" Style="{StaticResource FormTextBoxStyle}" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                        <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#98A2B3" FontSize="12" IsHitTestVisible="False" Text="Напр.: +380501234567">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=PhoneTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=PhoneTextBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding (Validation.Errors), ElementName=PhoneTextBox}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource InputErrorTextStyle}" Text="{Binding ErrorContent}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                    <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <TextBox x:Name="EmailTextBox" Style="{StaticResource FormTextBoxStyle}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                        <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#98A2B3" FontSize="12" IsHitTestVisible="False" Text="Напр.: office@postach.ua">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=EmailTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=EmailTextBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,12">
                    <TextBlock Text="ЄДРПОУ/ІПН" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <TextBox x:Name="TaxIdTextBox" Style="{StaticResource FormTextBoxStyle}" Text="{Binding TaxId, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#98A2B3" FontSize="12" IsHitTestVisible="False" Text="Опціонально">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=TaxIdTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=TaxIdTextBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0">
                    <TextBlock Text="Адреса" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <TextBox x:Name="AddressTextBox" Style="{StaticResource FormTextBoxStyle}" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#98A2B3" FontSize="12" IsHitTestVisible="False" Text="Напр.: м. Київ, вул. Січових Стрільців, 12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=AddressTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=AddressTextBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2">
                    <TextBlock Text="Примітка" Style="{StaticResource FieldLabelStyle}"/>
                    <Grid>
                        <TextBox x:Name="NoteTextBox" Style="{StaticResource FormTextBoxStyle}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="86" Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Margin="12,10,12,0" VerticalAlignment="Top" Foreground="#98A2B3" FontSize="12" Text="Додаткова інформація про умови співпраці" TextWrapping="Wrap" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=NoteTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=NoteTextBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,14,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Content="Скасувати" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CancelCommand}"/>
            <Button Content="Зберегти" Margin="10,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}"
                    IsEnabled="{Binding HasErrors, Converter={StaticResource InverseBoolConverter}}"/>
        </StackPanel>
    </Grid>
</Window>
