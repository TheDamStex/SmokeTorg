<Window x:Class="SmokeTorg.Presentation.Views.Windows.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Майстер первинного налаштування" Height="600" Width="820" WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl SelectedIndex="{Binding StepIndex}">
            <TabItem Header="1. Підключення">
                <StackPanel Margin="10">
                    <TextBlock Text="Параметри підключення" FontSize="18" FontWeight="SemiBold"/>
                    <UniformGrid Columns="2" Margin="0,12,0,0">
                        <TextBlock Text="Хост"/><TextBox Text="{Binding Host}"/>
                        <TextBlock Text="Порт"/><TextBox Text="{Binding Port}"/>
                        <TextBlock Text="База даних"/><TextBox Text="{Binding Database}"/>
                        <TextBlock Text="Користувач"/><TextBox Text="{Binding User}"/>
                        <TextBlock Text="Пароль"/><TextBox Text="{Binding Password}"/>
                    </UniformGrid>
                    <Button Content="Перевірити з’єднання" Command="{Binding CheckConnectionCommand}" Margin="0,12,0,0" Width="220"/>
                    <TextBlock Text="{Binding Status}" Foreground="DarkBlue" Margin="0,8,0,0"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="2. Ініціалізація БД">
                <StackPanel Margin="10">
                    <Button Content="Створити структуру БД" Command="{Binding InitializeSchemaCommand}" Width="220"/>
                    <ListBox ItemsSource="{Binding Logs}" Margin="0,12,0,0" Height="350"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="3. Адміністратор">
                <StackPanel Margin="10">
                    <UniformGrid Columns="2">
                        <TextBlock Text="Логін"/><TextBox Text="{Binding AdminLogin}"/>
                        <TextBlock Text="Пароль"/><TextBox Text="{Binding AdminPassword}"/>
                        <TextBlock Text="Підтвердження пароля"/><TextBox Text="{Binding AdminConfirmPassword}"/>
                        <TextBlock Text="ПІБ"/><TextBox Text="{Binding AdminFullName}"/>
                    </UniformGrid>
                    <Button Content="Створити адміністратора" Command="{Binding CreateAdminCommand}" Width="220" Margin="0,12,0,0"/>
                    <TextBlock Text="{Binding Status}" Margin="0,8,0,0" Foreground="DarkBlue"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="4. Завершення">
                <StackPanel Margin="10">
                    <TextBlock Text="Натисніть 'Завершити', щоб зберегти налаштування." FontSize="16"/>
                    <Button Content="Завершити" Command="{Binding FinishCommand}" Width="140" Margin="0,12,0,0"/>
                    <TextBlock Text="{Binding Status}" Margin="0,8,0,0"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Назад" Command="{Binding BackCommand}" Margin="0,0,8,0" Width="100"/>
            <Button Content="Далі" Command="{Binding NextCommand}" Width="100"/>
        </StackPanel>
    </Grid>
</Window>
