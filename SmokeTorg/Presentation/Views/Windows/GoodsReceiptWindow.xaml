<Window x:Class="SmokeTorg.Presentation.Views.Windows.GoodsReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редагування накладної приходу"
        Height="720"
        Width="1180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Накладна приходу" FontSize="26" FontWeight="SemiBold"/>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16" Margin="0,12,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Номер" FontWeight="SemiBold"/>
                <TextBox Grid.Column="1" Text="{Binding Number, Mode=OneWay}" IsReadOnly="True" Margin="6,0,12,8"/>
                <TextBlock Grid.Column="2" Text="Дата" FontWeight="SemiBold"/>
                <TextBox Grid.Column="3" Text="{Binding ReceiptDate, Mode=OneWay, StringFormat={}{0:dd.MM.yyyy HH:mm}}" IsReadOnly="True" Margin="6,0,12,8"/>
                <TextBlock Grid.Column="4" Text="Статус" FontWeight="SemiBold"/>
                <TextBox Grid.Column="5" Text="{Binding Status}" IsReadOnly="True" Margin="6,0,0,8"/>

                <TextBlock Grid.Row="1" Text="Постачальник" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                          ItemsSource="{Binding Suppliers}"
                          SelectedItem="{Binding SelectedSupplier}"
                          DisplayMemberPath="Name"
                          IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"
                          Margin="6,0,12,0"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="Створив" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding CreatedByLogin}" IsReadOnly="True" Margin="6,0,12,0"/>
                <StackPanel Grid.Row="1" Grid.Column="5">
                    <TextBlock Text="Приймає" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding AcceptedByLogin}" IsReadOnly="True"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="230"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}" Height="34" IsEnabled="{Binding IsReadOnly, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Grid.Column="1" Content="Додати за штрихкодом" Margin="8,0" Command="{Binding AddByBarcodeCommand}"/>
                    <TextBox Grid.Column="2" Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}" Height="34"/>
                    <Button Grid.Column="3" Content="Пошук" Margin="8,0" Command="{Binding SearchProductCommand}"/>
                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <ComboBox Width="260" ItemsSource="{Binding ProductSearchResults}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedSearchProduct}"/>
                        <Button Content="Додати товар" Margin="8,0" Command="{Binding AddProductCommand}" CommandParameter="{Binding SelectedSearchProduct}"/>
                        <Button Content="Додати постачальника" Command="{Binding AddSupplierCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1" AutoGenerateColumns="False" ItemsSource="{Binding Items}" CanUserAddRows="False" IsReadOnly="{Binding IsReadOnly}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Штрихкод" Binding="{Binding Barcode}" Width="150" IsReadOnly="True"/>
                    <DataGridTextColumn Header="К-сть" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                    <DataGridTextColumn Header="Ціна закупівлі" Binding="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                    <DataGridTextColumn Header="Сума" Binding="{Binding Sum}" Width="130" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Видалити"
                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,14,0,0">
            <TextBlock Text="{Binding Total, StringFormat=Разом: {0:N2}}" FontSize="22" FontWeight="SemiBold" Foreground="#FF7A00" DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Content="Зберегти як чернетку" Command="{Binding SaveDraftCommand}" Margin="0,0,8,0"/>
                <Button Content="Провести" Command="{Binding PostCommand}" Margin="0,0,8,0"/>
                <Button Content="Скасувати накладну" Command="{Binding CancelReceiptCommand}" Margin="0,0,8,0"/>
                <Button Content="Закрити" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
