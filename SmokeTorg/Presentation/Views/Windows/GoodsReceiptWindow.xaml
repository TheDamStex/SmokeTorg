<Window x:Class="SmokeTorg.Presentation.Views.Windows.GoodsReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Почати прихід товару"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Почати прихід товару" FontSize="26" FontWeight="SemiBold"/>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,14,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="Name" Height="36"/>
                <Button Grid.Column="1" Margin="10,0,0,0" Content="Додати постачальника" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding AddSupplierCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Style="{StaticResource AppTextBoxStyle}" Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                        <Button Content="Пошук" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding SearchProductCommand}"/>
                        <ComboBox Width="250" Margin="8,0,0,0" ItemsSource="{Binding ProductSearchResults}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedSearchProduct}"/>
                        <Button Content="Додати" Margin="8,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding AddProductCommand}" CommandParameter="{Binding SelectedSearchProduct}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1" Style="{StaticResource AppDataGridStyle}" ItemsSource="{Binding Items}" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="К-сть" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                    <DataGridTextColumn Header="Ціна закупівлі" Binding="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged}" Width="170"/>
                    <DataGridTextColumn Header="Сума" Binding="{Binding Sum}" Width="140" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Видалити" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Total, StringFormat='Разом: {0:N2}'}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Зберегти як чернетку" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding SaveDraftCommand}"/>
                <Button Content="Провести" Margin="8,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding PostCommand}"/>
                <Button Content="Скасувати" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
