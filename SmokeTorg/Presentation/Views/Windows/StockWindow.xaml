<Window x:Class="SmokeTorg.Presentation.Views.Windows.StockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Переглянути склад"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Склад / Залишки" FontSize="26" FontWeight="SemiBold"/>

        <Border Grid.Row="1" Margin="0,14,0,10" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Style="{StaticResource AppTextBoxStyle}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <CheckBox Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Content="Нижче мінімуму" IsChecked="{Binding BelowMinimumOnly}"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" Style="{StaticResource AppDataGridStyle}" ItemsSource="{Binding ItemsView}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                <DataGridTextColumn Header="Категорія" Binding="{Binding Category}" Width="220"/>
                <DataGridTextColumn Header="Залишок" Binding="{Binding Quantity}" Width="110"/>
                <DataGridTextColumn Header="Мін.залишок" Binding="{Binding MinQuantity}" Width="120"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Оновити" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshCommand}"/>
            <Button Content="Експорт (заглушка)" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ExportCommand}"/>
            <Button Content="Закрити" Margin="8,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding CloseCommand}"/>
        </StackPanel>
    </Grid>
</Window>
