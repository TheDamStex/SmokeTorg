<Window x:Class="SmokeTorg.Presentation.Views.Windows.AddSupplierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Додати постачальника"
        Height="360"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Новий постачальник" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,14"/>
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0" Style="{StaticResource AppTextBoxStyle}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                <TextBox Grid.Row="1" Margin="0,10,0,0" Style="{StaticResource AppTextBoxStyle}" Text="{Binding ContactPerson, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource AppTextBoxStyle}" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                <TextBox Grid.Row="3" Margin="0,10,0,0" Style="{StaticResource AppTextBoxStyle}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,14,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Content="Скасувати" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CancelCommand}"/>
            <Button Content="Зберегти" Margin="10,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}"
                    IsEnabled="{Binding HasErrors, Converter={StaticResource InverseBoolConverter}}"/>
        </StackPanel>
    </Grid>
</Window>
