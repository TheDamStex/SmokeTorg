<Window x:Class="SmokeTorg.Presentation.Views.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вхід" Height="260" Width="380" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="Вхід до системи" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
        <TextBlock Text="Логін"/><TextBox Text="{Binding Username}"/>
        <TextBlock Text="Пароль" Margin="0,8,0,0"/><TextBox Text="{Binding Password}"/>
        <Button Content="Увійти" Click="OnLoginClick" Margin="0,12,0,0" Height="32"/>
    </StackPanel>
</Window>
