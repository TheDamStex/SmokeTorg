<Window x:Class="SmokeTorg.Presentation.Views.Windows.DbSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Налаштування БД" Height="360" Width="500" WindowStartupLocation="CenterOwner">
    <StackPanel Margin="12">
        <TextBlock Text="Хост"/><TextBox Text="{Binding Host}"/>
        <TextBlock Text="Порт"/><TextBox Text="{Binding Port}"/>
        <TextBlock Text="База даних"/><TextBox Text="{Binding Database}"/>
        <TextBlock Text="Користувач"/><TextBox Text="{Binding User}"/>
        <TextBlock Text="Пароль"/><TextBox Text="{Binding Password}"/>
        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="Завантажити" Command="{Binding LoadCommand}" Width="120" Margin="0,0,8,0"/>
            <Button Content="Зберегти" Command="{Binding SaveCommand}" Width="120"/>
        </StackPanel>
        <TextBlock Text="{Binding Status}" Margin="0,8,0,0"/>
    </StackPanel>
</Window>
