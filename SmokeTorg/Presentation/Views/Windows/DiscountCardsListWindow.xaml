<Window x:Class="SmokeTorg.Presentation.Views.Windows.DiscountCardsListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Список дисконтних карток"
        Width="1080"
        Height="720"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Дисконтні картки" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="Пошук за номером картки, клієнтом або телефоном" Foreground="#667085"/>
                </StackPanel>
                <TextBox Grid.Column="1"
                         Width="340"
                         Style="{StaticResource AppTextBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Padding="8">
                <StackPanel>
                    <Button Command="{Binding AddCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Додати"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Редагувати"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeleteCommand}" Style="{StaticResource SecondaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Видалити"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="0">
                <DataGrid Style="{StaticResource AppDataGridStyle}"
                          ItemsSource="{Binding CardsView}"
                          SelectedItem="{Binding SelectedCard}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Код (№ картки)" Binding="{Binding DiscountCardNumber}" Width="170"/>
                        <DataGridTextColumn Header="Клієнт" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="150"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding DiscountType}" Width="130"/>
                        <DataGridTextColumn Header="Регіон" Binding="{Binding Region}" Width="130"/>
                        <DataGridTextColumn Header="Мова" Binding="{Binding Note}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Обрати" Command="{Binding SelectCommand}" Style="{StaticResource PrimaryButtonStyle}" MinWidth="120" Margin="0,0,8,0"/>
            <Button Content="Закрити" Command="{Binding CloseCommand}" Style="{StaticResource SecondaryButtonStyle}" MinWidth="120"/>
        </StackPanel>
    </Grid>
</Window>
