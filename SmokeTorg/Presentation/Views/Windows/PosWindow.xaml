<Window x:Class="SmokeTorg.Presentation.Views.Windows.PosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Реалізація / Каса"
        Height="780"
        Width="1220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        Background="{StaticResource WindowBackgroundBrush}"
        FocusManager.FocusedElement="{Binding ElementName=BarcodeBox}">
    <Window.InputBindings>
        <KeyBinding Key="F6" Command="{Binding PayCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand}"/>
    </Window.InputBindings>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Реалізація / Каса" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="{Binding WorkDate, StringFormat='Дата: {0:dd.MM.yyyy HH:mm}'}" Foreground="#667085"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding TerminalInfo}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding CashierInfo}" Foreground="#667085"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{Binding CustomerInfo}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding CardInfo}" Foreground="#667085"/>
                </StackPanel>
                <StackPanel Grid.Column="3" HorizontalAlignment="Right">
                    <TextBlock Text="Знижка/бонус" Foreground="#667085" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding Discount, StringFormat='₴ {0:N2}'}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="8" Margin="0,8,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <WrapPanel>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Command="{Binding NewCheckCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7C3;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Новий чек"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Command="{Binding SearchGoodsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Пошук товару"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Command="{Binding OpenClientCardCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Клієнт/картка"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Command="{Binding ReturnCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Повернення"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" Command="{Binding DiscountCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEC1B;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Знижка"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}" Command="{Binding PrintCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0"/>
                            <TextBlock Text="Друк"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <Grid Grid.Column="1" Margin="12,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="BarcodeBox"
                             Grid.Column="0"
                             Style="{StaticResource AppTextBoxStyle}"
                             Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Штрихкод/пошук">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding ScanBarcodeCommand}"/>
                        </TextBox.InputBindings>
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource AppTextBoxStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasBarcodeError}" Value="True">
                                        <Setter Property="BorderBrush" Value="#D92D20"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button Grid.Column="1" Margin="6,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Content="Додати" Command="{Binding ScanBarcodeCommand}"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid Style="{StaticResource AppDataGridStyle}" ItemsSource="{Binding CheckItems}" AutoGenerateColumns="False" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Штрихкод" Binding="{Binding Barcode}" Width="170" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Назва товару" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="К-сть" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="-" Width="28" Height="26" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DataContext.DecreaseCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding Quantity}" Margin="10,0" VerticalAlignment="Center"/>
                                    <Button Content="+" Width="28" Height="26" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DataContext.IncreaseCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Ціна" Binding="{Binding Price, StringFormat={}{0:N2}}" Width="110"/>
                    <DataGridTextColumn Header="Сума" Binding="{Binding Sum, StringFormat={}{0:N2}}" Width="130" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,8,0,0" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="Повна сума" Foreground="#667085"/>
                    <TextBlock Text="{Binding Subtotal, StringFormat='₴ {0:N2}'}" FontWeight="SemiBold" FontSize="18"/>
                    <TextBlock Text="Немає знижки/Знижка" Margin="0,6,0,0" Foreground="#667085"/>
                    <TextBlock Text="{Binding Discount, StringFormat='₴ {0:N2}'}" FontWeight="SemiBold" FontSize="18"/>
                    <TextBlock Text="Сума знижки" Margin="0,6,0,0" Foreground="#667085"/>
                    <TextBlock Text="{Binding Discount, StringFormat='₴ {0:N2}'}" FontWeight="SemiBold" FontSize="18"/>
                    <TextBlock Text="Передоплата" Margin="0,6,0,0" Foreground="#667085"/>
                    <TextBlock Text="{Binding Prepayment, StringFormat='₴ {0:N2}'}" FontWeight="SemiBold" FontSize="18"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="До оплати" HorizontalAlignment="Center" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Total, StringFormat='₴ {0:N2}'}" FontSize="42" FontWeight="Bold" Foreground="#C05621" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Width="280">
                    <TextBlock Text="Спосіб оплати" FontWeight="SemiBold"/>
                    <ComboBox Style="{StaticResource AppComboBoxStyle}" ItemsSource="{Binding PaymentOptions}" SelectedItem="{Binding PaymentType}"/>
                    <TextBlock Text="Отримано" Margin="0,6,0,0" FontWeight="SemiBold"/>
                    <TextBox Style="{StaticResource AppTextBoxStyle}" Text="{Binding Received, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                    <TextBlock Text="{Binding Change, StringFormat='Решта: ₴ {0:N2}'}" Margin="0,6,0,0" FontWeight="SemiBold" FontSize="16"/>
                </StackPanel>

                <WrapPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0" HorizontalAlignment="Center">
                    <Button Content="Оплатити (F6)" Command="{Binding PayCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" MinWidth="170"/>
                    <Button Content="Вибір зі складу" Command="{Binding SearchGoodsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" MinWidth="150"/>
                    <Button Content="Оплатити карткою" Command="{Binding PayCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" MinWidth="150"/>
                    <Button Content="Скасувати" Command="{Binding CancelCheckCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" MinWidth="120"/>
                    <Button Content="Повернення" Command="{Binding ReturnCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" MinWidth="120"/>
                    <Button Content="Закрити (Esc)" Command="{Binding CloseCommand}" Style="{StaticResource SecondaryButtonStyle}" MinWidth="120"/>
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
