<Window x:Class="SmokeTorg.Presentation.Views.Windows.PosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Відкрити реалізацію"
        Height="760"
        Width="1140"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        Background="{StaticResource WindowBackgroundBrush}"
        FocusManager.FocusedElement="{Binding ElementName=SearchBox}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Реалізація / Каса"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="#222"/>

        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="0,16,0,16"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.8*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox"
                         Style="{StaticResource AppTextBoxStyle}"
                         Height="38"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="1"
                        Margin="10,0,0,0"
                        Content="Пошук"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding SearchCommand}"/>
                <ComboBox Grid.Column="2"
                          Margin="10,0,0,0"
                          Height="38"
                          ItemsSource="{Binding SearchResults}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding SelectedProduct}"/>
                <Button Grid.Column="3"
                        Margin="10,0,0,0"
                        Content="Додати"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding AddItemCommand}"
                        CommandParameter="{Binding SelectedProduct}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid Style="{StaticResource AppDataGridStyle}"
                      ItemsSource="{Binding CheckItems}"
                      AutoGenerateColumns="False"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="К-сть" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="−"
                                            Width="30"
                                            Height="30"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding DataContext.DecreaseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                    <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center" Margin="12,0" FontWeight="SemiBold"/>
                                    <Button Content="+"
                                            Width="30"
                                            Height="30"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding DataContext.IncreaseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Ціна" Binding="{Binding Price}" Width="120"/>
                    <DataGridTextColumn Header="Сума" Binding="{Binding Sum}" Width="140" IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑"
                                        Width="34"
                                        Height="30"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3"
                Style="{StaticResource CardStyle}"
                Margin="0,16,0,0"
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Проміжний підсумок" Foreground="#555"/>
                    <TextBlock Text="{Binding Subtotal, StringFormat='₴ {0:N2}'}" Margin="0,2,0,12" FontSize="18" FontWeight="SemiBold"/>

                    <TextBlock Text="Знижка" Foreground="#555"/>
                    <TextBlock Text="{Binding Discount, StringFormat='₴ {0:N2}'}" Margin="0,2,0,12" FontSize="18" FontWeight="SemiBold"/>

                    <TextBlock Text="До оплати" Foreground="#555"/>
                    <TextBlock Text="{Binding Total, StringFormat='₴ {0:N2}'}"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#FF7A00"/>
                </StackPanel>

                <Border Grid.Column="1" Margin="20,0" Background="#EAEAEA" Width="1"/>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Спосіб оплати" FontWeight="SemiBold"/>
                    <ComboBox Grid.Row="1"
                              Margin="0,6,0,0"
                              Height="36"
                              ItemsSource="{Binding PaymentOptions}"
                              SelectedItem="{Binding PaymentType}"/>

                    <TextBlock Grid.Row="2" Margin="0,12,0,0" Text="Отримано" FontWeight="SemiBold"/>
                    <TextBox Grid.Row="3"
                             Margin="0,6,0,0"
                             Style="{StaticResource AppTextBoxStyle}"
                             Text="{Binding Received, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="4"
                               Margin="0,12,0,0"
                               Text="{Binding Change, StringFormat='Решта: ₴ {0:N2}'}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,20,20">
            <Button Content="Відмінити чек"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding CancelCheckCommand}"/>
            <Button Content="Закрити"
                    Margin="12,0,0,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding CloseCommand}"/>
            <Button Content="Оплатити"
                    Margin="12,0,0,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding PayCommand}"/>
        </StackPanel>
    </Grid>
</Window>
