<Window x:Class="SmokeTorg.Presentation.Views.Windows.PosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Відкрити реалізацію"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundBrush}"
        FocusManager.FocusedElement="{Binding ElementName=SearchBox}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Реалізація / Каса" FontSize="26" FontWeight="SemiBold"/>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,14,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Style="{StaticResource AppTextBoxStyle}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="1" Margin="8,0,0,0" Content="Пошук" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding SearchCommand}"/>
                <ComboBox Grid.Column="2" Margin="8,0,0,0" ItemsSource="{Binding SearchResults}" DisplayMemberPath="Name" SelectedItem="{Binding SelectedProduct}"/>
                <Button Grid.Column="3" Margin="8,0,0,0" Content="Додати" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding AddItemCommand}" CommandParameter="{Binding SelectedProduct}"/>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" Style="{StaticResource AppDataGridStyle}" ItemsSource="{Binding CheckItems}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="К-сть" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="-" Width="26" Height="26" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DataContext.DecreaseCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center" Margin="10,0"/>
                                <Button Content="+" Width="26" Height="26" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DataContext.IncreaseCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Ціна" Binding="{Binding Price}" Width="120"/>
                <DataGridTextColumn Header="Сума" Binding="{Binding Sum}" Width="140" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Видалити" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Видалити" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="290"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Subtotal, StringFormat='Проміжний підсумок: {0:N2}'}" FontSize="15"/>
                    <TextBlock Text="{Binding Discount, StringFormat='Знижка: {0:N2}'}" FontSize="15"/>
                    <TextBlock Text="{Binding Total, StringFormat='До оплати: {0:N2}'}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <ComboBox ItemsSource="{Binding PaymentOptions}" SelectedItem="{Binding PaymentType}" Height="32"/>
                    <TextBox Margin="0,8,0,0" Style="{StaticResource AppTextBoxStyle}" Text="{Binding Received, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Margin="0,8,0,0" Text="{Binding Change, StringFormat='Решта: {0:N2}'}" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="10,0,0,0">
                    <Button Content="Оплатити" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding PayCommand}"/>
                    <Button Content="Відмінити чек" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CancelCheckCommand}"/>
                    <Button Content="Закрити" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
