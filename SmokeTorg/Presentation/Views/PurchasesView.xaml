<UserControl x:Class="SmokeTorg.Presentation.Views.PurchasesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Language="uk-UA">
    <UserControl.Resources>
        <Style x:Key="ActionPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Background" Value="#2E6AE6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2558C8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#A0AEC0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionPrimaryButtonStyle}">
            <Setter Property="Background" Value="#E9EEF9"/>
            <Setter Property="Foreground" Value="#243B63"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DCE5F8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#F0F2F5"/>
                    <Setter Property="Foreground" Value="#98A2B3"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FilterInputStyle" TargetType="Control">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E4E7EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2F6"/>
            <Setter Property="RowHeight" Value="46"/>
            <Setter Property="ColumnHeaderHeight" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#344054"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E4E7EC"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2F6FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E9F0FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#E4E7EC"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status, Converter={StaticResource PurchaseStatusToUkrainianConverter}}" Value="Проведено">
                    <Setter Property="Background" Value="#D1FADF"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status, Converter={StaticResource PurchaseStatusToUkrainianConverter}}" Value="Скасовано">
                    <Setter Property="Background" Value="#FEE4E2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475467"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status, Converter={StaticResource PurchaseStatusToUkrainianConverter}}" Value="Проведено">
                    <Setter Property="Foreground" Value="#067647"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status, Converter={StaticResource PurchaseStatusToUkrainianConverter}}" Value="Скасовано">
                    <Setter Property="Foreground" Value="#B42318"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Накладні приходу"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="#101828"
                           Margin="0,0,0,14"/>

                <StackPanel Orientation="Horizontal">
                    <Button Content="+ Створити накладну"
                            Command="{Binding CreateDraftCommand}"
                            IsEnabled="{Binding CanCreateInvoice}"
                            Style="{StaticResource ActionPrimaryButtonStyle}"/>
                    <Button Content="Відкрити"
                            Command="{Binding OpenSelectedCommand}"
                            IsEnabled="{Binding CanOpenSelected}"
                            Style="{StaticResource ActionSecondaryButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Фільтри"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#101828"
                           Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="230"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Номер" Margin="0,0,0,4" Foreground="#475467"/>
                        <TextBox Text="{Binding NumberSearch, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Введіть номер накладної"
                                 Style="{StaticResource FilterInputStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Дата від" Margin="0,0,0,4" Foreground="#475467"/>
                        <DatePicker Language="uk-UA"
                                    SelectedDateFormat="Short"
                                    SelectedDate="{Binding FromDate}"
                                    Style="{StaticResource FilterInputStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Дата до" Margin="0,0,0,4" Foreground="#475467"/>
                        <DatePicker Language="uk-UA"
                                    SelectedDateFormat="Short"
                                    SelectedDate="{Binding ToDate}"
                                    Style="{StaticResource FilterInputStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Постачальник" Margin="0,0,0,4" Foreground="#475467"/>
                        <ComboBox ItemsSource="{Binding Suppliers}"
                                  SelectedItem="{Binding SelectedFilterSupplier}"
                                  DisplayMemberPath="Name"
                                  ToolTip="Оберіть постачальника"
                                  Style="{StaticResource FilterInputStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Статус" Margin="0,0,0,4" Foreground="#475467"/>
                        <ComboBox ItemsSource="{Binding Statuses}"
                                  SelectedItem="{Binding SelectedFilterStatus}"
                                  Style="{StaticResource FilterInputStyle}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource PurchaseStatusToUkrainianConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="Фільтр"
                                Command="{Binding ApplyFiltersCommand}"
                                Style="{StaticResource ActionPrimaryButtonStyle}"
                                Height="36"
                                Padding="16,0"/>
                        <Button Content="Скинути"
                                Command="{Binding ClearFiltersCommand}"
                                Style="{StaticResource ActionSecondaryButtonStyle}"
                                Height="36"
                                Padding="16,0"
                                Margin="0,0,10,0"/>
                        <Button Content="Оновити"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource ActionSecondaryButtonStyle}"
                                Height="36"
                                Padding="16,0"
                                Margin="0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="14" Padding="0" BorderBrush="#E4E7EC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Таблиця накладних"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#101828"
                           Margin="16,14,16,10"/>

                <DataGrid Grid.Row="1"
                          Margin="8,0,8,8"
                          ItemsSource="{Binding FilteredPurchases}"
                          SelectedItem="{Binding Selected}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                    <DataGrid.InputBindings>
                        <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenSelectedCommand}"/>
                    </DataGrid.InputBindings>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Номер" Binding="{Binding Number}" Width="170" SortMemberPath="Number"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="170" SortMemberPath="CreatedAt"/>
                        <DataGridTextColumn Header="Постачальник" Binding="{Binding SupplierName}" Width="*" SortMemberPath="SupplierName"/>

                        <DataGridTemplateColumn Header="Статус" Width="130" SortMemberPath="Status">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StatusBadgeStyle}" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status, Converter={StaticResource PurchaseStatusToUkrainianConverter}}"
                                                   Style="{StaticResource StatusTextStyle}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Створив" Binding="{Binding CreatedByLogin}" Width="150" SortMemberPath="CreatedByLogin"/>
                        <DataGridTextColumn Header="Приймає" Binding="{Binding AcceptedByLogin}" Width="150" SortMemberPath="AcceptedByLogin"/>
                        <DataGridTextColumn Header="Сума" Binding="{Binding TotalAmount, StringFormat={}{0:N2}}" Width="120" SortMemberPath="TotalAmount"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
