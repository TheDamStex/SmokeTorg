<UserControl x:Class="SmokeTorg.Presentation.Views.PurchasesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Накладні приходу"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="White" Padding="10" CornerRadius="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Пошук за номером" Margin="0,0,0,4" Foreground="#475467"/>
                    <TextBox Height="34"
                             VerticalContentAlignment="Center"
                             Text="{Binding NumberSearch, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Введіть номер накладної"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="Дата від" Margin="0,0,0,4" Foreground="#475467"/>
                    <DatePicker Height="34"
                                Language="uk-UA"
                                SelectedDateFormat="Short"
                                SelectedDate="{Binding FromDate}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="Дата до" Margin="0,0,0,4" Foreground="#475467"/>
                    <DatePicker Height="34"
                                Language="uk-UA"
                                SelectedDateFormat="Short"
                                SelectedDate="{Binding ToDate}"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="0,0,8,0">
                    <TextBlock Text="Постачальник" Margin="0,0,0,4" Foreground="#475467"/>
                    <ComboBox Height="34"
                              ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding SelectedFilterSupplier}"
                              DisplayMemberPath="Name"
                              ToolTip="Оберіть постачальника"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="0,0,8,0">
                    <TextBlock Text="Статус" Margin="0,0,0,4" Foreground="#475467"/>
                    <ComboBox Height="34"
                              ItemsSource="{Binding Statuses}"
                              SelectedItem="{Binding SelectedFilterStatus}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource PurchaseStatusToUkrainianConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="6" Orientation="Horizontal">
                    <Button Content="Фільтрувати" Command="{Binding ApplyFiltersCommand}" Margin="0,0,8,0"/>
                    <Button Content="Скинути" Command="{Binding ClearFiltersCommand}"/>
                </StackPanel>
                <Button Grid.Column="7" Content="Оновити" Command="{Binding RefreshCommand}" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="White" Padding="10" CornerRadius="10" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <ComboBox Width="250" Margin="0,0,8,0" Style="{StaticResource AppComboBoxStyle}" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedCreateSupplier, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" DisplayMemberPath="Name"/>
                    <Button Content="Створити накладну" Command="{Binding CreateDraftCommand}" IsEnabled="{Binding CanCreateInvoice}"/>
                    <Button Content="Відкрити вибрану" Command="{Binding OpenSelectedCommand}" IsEnabled="{Binding CanOpenSelected}" Margin="8,0,0,0"/>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding FilteredPurchases}"
                      SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.InputBindings>
                    <MouseBinding Gesture="LeftDoubleClick" Command="{Binding OpenSelectedCommand}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Номер" Binding="{Binding Number}" Width="170"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="150"/>
                    <DataGridTextColumn Header="Постачальник" Binding="{Binding SupplierName}" Width="*"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status, Converter={StaticResource PurchaseStatusToUkrainianConverter}}" Width="110"/>
                    <DataGridTextColumn Header="Створив" Binding="{Binding CreatedByLogin}" Width="150"/>
                    <DataGridTextColumn Header="Приймає" Binding="{Binding AcceptedByLogin}" Width="150"/>
                    <DataGridTextColumn Header="Сума" Binding="{Binding TotalAmount, StringFormat={}{0:N2}}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
