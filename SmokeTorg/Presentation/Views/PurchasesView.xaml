<UserControl x:Class="SmokeTorg.Presentation.Views.PurchasesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <StackPanel>
            <Button Content="Обновить" Command="{Binding RefreshCommand}" Width="120" Margin="0,0,0,6"/>
            <DataGrid ItemsSource="{Binding Purchases}" SelectedItem="{Binding Selected}" AutoGenerateColumns="False" Height="450">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="120"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding Total}" Width="80"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
            <Button Content="Провести" Command="{Binding PostCommand}" Width="120" Margin="0,6,0,0"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="8,0,0,0">
            <TextBlock Text="Новая закупка" FontWeight="Bold"/>
            <WrapPanel Margin="0,4,0,6">
                <Button Content="Новый" Command="{Binding AddCommand}" Margin="0,0,8,0"/>
                <Button Content="Сохранить" Command="{Binding SaveCommand}"/>
            </WrapPanel>

            <TextBlock Text="Товары" FontWeight="Bold"/>
            <ListBox ItemsSource="{Binding Products}" Height="140" DisplayMemberPath="Name"/>
            <TextBlock Text="* Добавление строки можно расширить диалогом выбора товара" FontStyle="Italic" Margin="0,4,0,0"/>
            <DataGrid ItemsSource="{Binding Current.Items}" AutoGenerateColumns="False" Height="250" Margin="0,8,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Штрихкод" Binding="{Binding BarcodeDisplay}" Width="140"/>
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                    <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</UserControl>
