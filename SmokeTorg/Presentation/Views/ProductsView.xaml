<UserControl x:Class="SmokeTorg.Presentation.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Margin="0,0,10,0"
                         Style="{StaticResource AppTextBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                <ComboBox Grid.Column="1"
                          Margin="0,0,10,0"
                          Style="{StaticResource AppComboBoxStyle}"
                          ItemsSource="{Binding CategoryFilters}"
                          SelectedItem="{Binding SelectedCategoryFilter}"
                          DisplayMemberPath="Name"/>

                <CheckBox Grid.Column="2"
                          Margin="0,0,16,0"
                          VerticalAlignment="Center"
                          Content="Нижче мінімуму"
                          IsChecked="{Binding BelowMinimumOnly}"/>

                <ComboBox Grid.Column="3"
                          Width="170"
                          Margin="0,0,10,0"
                          Style="{StaticResource AppComboBoxStyle}"
                          ItemsSource="{Binding ActivityFilters}"
                          SelectedItem="{Binding SelectedActivityFilter}"
                          DisplayMemberPath="Name"/>

                <Border Grid.Column="4"
                        Margin="0,0,10,0"
                        CornerRadius="6"
                        BorderBrush="#E4E7EC"
                        BorderThickness="1"
                        Background="#F9FAFB"
                        Padding="10,6"
                        VerticalAlignment="Center">
                    <TextBlock Text="Сканер: штрихкод у формі редагування" Foreground="#475467"/>
                </Border>

                <Button Grid.Column="5"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Content="Оновити"
                        Command="{Binding RefreshCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1.25*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Таблиця товарів" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="#1F2937"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ItemsView}"
                              SelectedItem="{Binding Selected}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="White"
                              AlternatingRowBackground="#FAFAFA"
                              BorderBrush="#EAECF0"
                              BorderThickness="1">
                        <DataGrid.InputBindings>
                            <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditCommand}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBelowMinimum}" Value="True">
                                        <Setter Property="Background" Value="#FFF1F3"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsOutOfStock}" Value="True">
                                        <Setter Property="Background" Value="#FEE4E2"/>
                                        <Setter Property="Foreground" Value="#B42318"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding Sku}" Width="*"/>
                            <DataGridTextColumn Header="Штрихкод" Binding="{Binding Barcode}" Width="1.2*"/>
                            <DataGridTextColumn Header="Категорія" Binding="{Binding CategoryName}" Width="1.2*"/>
                            <DataGridTextColumn Header="Ціна закупівлі" Binding="{Binding PurchasePrice, StringFormat=N2}" Width="*"/>
                            <DataGridTextColumn Header="Ціна продажу" Binding="{Binding SalePrice, StringFormat=N2}" Width="*"/>
                            <DataGridTextColumn Header="Залишок" Binding="{Binding StockQuantity, StringFormat=N2}" Width="*"/>
                            <DataGridTextColumn Header="Мін. залишок" Binding="{Binding MinStock, StringFormat=N2}" Width="*"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding StockStatusDisplay}" Width="*"/>
                            <DataGridTextColumn Header="Активність" Binding="{Binding ActivityDisplay}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Форма товару" FontSize="18" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,14"/>

                    <TextBlock Grid.Row="1" Text="Назва" Margin="0,0,0,4"/>
                    <TextBox Grid.Row="2" Style="{StaticResource AppTextBoxStyle}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Артикул" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource AppTextBoxStyle}" Text="{Binding Sku, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Штрихкод" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource AppTextBoxStyle}"
                                     FontSize="16"
                                     FontWeight="SemiBold"
                                     Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Grid.Row="4" Text="Категорія" Margin="0,10,0,4"/>
                    <ComboBox Grid.Row="5"
                              Style="{StaticResource AppComboBoxStyle}"
                              ItemsSource="{Binding CategoryOptions}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name"
                              SelectedValue="{Binding CategoryId, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>

                    <Grid Grid.Row="6" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Ціна закупівлі" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource AppTextBoxStyle}" Text="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Ціна продажу" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource AppTextBoxStyle}" Text="{Binding SalePrice, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="7" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Мін. залишок" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource AppTextBoxStyle}" Text="{Binding MinStock, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" Content="Активний" VerticalAlignment="Bottom" IsChecked="{Binding IsActive}" Margin="10,0,0,8"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,12,0,0" Padding="14,10">
            <WrapPanel>
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Новий" Command="{Binding AddCommand}" Margin="0,0,8,0"/>
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Змінити" Command="{Binding EditCommand}" Margin="0,0,8,0"/>
                <Button Style="{StaticResource PrimaryButtonStyle}" Content="Зберегти" Command="{Binding SaveCommand}" IsEnabled="{Binding HasErrors, Converter={StaticResource InverseBoolConverter}}" Margin="0,0,8,0"/>
                <Button Style="{StaticResource DangerButtonStyle}" Content="Деактивувати" Command="{Binding DeleteCommand}" Margin="0,0,8,0"/>
                <Button Style="{StaticResource SecondaryButtonStyle}" Content="Скасувати" Command="{Binding CancelCommand}"/>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>
