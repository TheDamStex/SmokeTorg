<UserControl x:Class="SmokeTorg.Presentation.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel>
            <TextBox Width="240" Text="{Binding SearchText}" Margin="0,0,8,0"/>
            <Button Content="Поиск" Command="{Binding SearchCommand}" Margin="0,0,8,0"/>
            <Button Content="Обновить" Command="{Binding RefreshCommand}"/>
        </WrapPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Sku}" Width="120"/>
                <DataGridTextColumn Header="Штрихкод" Binding="{Binding Barcode}" Width="120"/>
                <DataGridTextColumn Header="Цена зак." Binding="{Binding PurchasePrice}" Width="100"/>
                <DataGridTextColumn Header="Цена прод." Binding="{Binding SalePrice}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Новый" Command="{Binding AddCommand}" Margin="0,0,8,0"/>
            <Button Content="Изменить" Command="{Binding EditCommand}" Margin="0,0,8,0"/>
            <Button Content="Удалить" Command="{Binding DeleteCommand}" Margin="0,0,8,0"/>
            <Button Content="Сохранить" Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
