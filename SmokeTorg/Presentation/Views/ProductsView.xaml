<UserControl x:Class="SmokeTorg.Presentation.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WrapPanel>
            <TextBox Width="240" Style="{StaticResource AppTextBoxStyle}" Text="{Binding SearchText}" Margin="0,0,8,0"/>
            <Button Content="Пошук" Command="{Binding SearchCommand}" Margin="0,0,8,0"/>
            <Button Content="Оновити" Command="{Binding RefreshCommand}"/>
        </WrapPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Sku}" Width="120"/>
                <DataGridTextColumn Header="Штрихкод" Binding="{Binding Barcode}" Width="140"/>
                <DataGridTextColumn Header="Ціна зак." Binding="{Binding PurchasePrice}" Width="100"/>
                <DataGridTextColumn Header="Ціна прод." Binding="{Binding SalePrice}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Новий" Command="{Binding AddCommand}" Margin="0,0,8,0"/>
            <Button Content="Змінити" Command="{Binding EditCommand}" Margin="0,0,8,0"/>
            <Button Content="Видалити" Command="{Binding DeleteCommand}" Margin="0,0,8,0"/>
            <Button Content="Зберегти" Command="{Binding SaveCommand}" IsEnabled="{Binding HasErrors, Converter={StaticResource InverseBoolConverter}}"/>
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource AppTextBoxStyle}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" ToolTip="Назва"/>
            <TextBox Grid.Column="1" Margin="0,0,8,0" Style="{StaticResource AppTextBoxStyle}" Text="{Binding Sku, UpdateSourceTrigger=PropertyChanged}" ToolTip="Артикул"/>
            <TextBox Grid.Column="2" Margin="0,0,8,0" Style="{StaticResource AppTextBoxStyle}" Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" ToolTip="Штрихкод"/>
            <TextBox Grid.Column="3" Margin="0,0,8,0" Style="{StaticResource AppTextBoxStyle}" Text="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" ToolTip="Ціна закупівлі"/>
            <TextBox Grid.Column="4" Margin="0,0,8,0" Style="{StaticResource AppTextBoxStyle}" Text="{Binding SalePrice, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" ToolTip="Ціна продажу"/>
            <TextBox Grid.Column="5" Style="{StaticResource AppTextBoxStyle}" Text="{Binding MinStock, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" ToolTip="Мін. залишок"/>
        </Grid>
    </Grid>
</UserControl>
