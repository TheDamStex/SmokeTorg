<Window x:Class="SmokeTorg.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SmokeTorg.Presentation.Views"
        xmlns:vm="clr-namespace:SmokeTorg.Presentation.ViewModels"
        Title="SmokeTorg" Height="760" Width="1280"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        FontFamily="Segoe UI">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:PosViewModel}">
            <views:PosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
            <views:ProductsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PurchasesViewModel}">
            <views:PurchasesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
            <views:PlaceholderView/>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderPanelStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Border Width="38" Height="38" CornerRadius="8" Background="#FF7A00" VerticalAlignment="Center">
                        <TextBlock Text="ST" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="{Binding AppTitle}" FontSize="20" FontWeight="Bold" Foreground="#333"/>
                        <TextBlock Text="{Binding StoreName}" Foreground="#555"/>
                        <TextBlock Text="{Binding DbName}" Foreground="#777"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <Button Style="{StaticResource RibbonMenuButtonStyle}" Command="{Binding OpenHomeCommand}" Content="&#xE8A5;  Файл"/>
                    <Button Style="{StaticResource RibbonMenuButtonStyle}" Command="{Binding OpenProductsCommand}" Content="&#xE14C;  Товары"/>
                    <Button Style="{StaticResource RibbonMenuButtonStyle}" Command="{Binding OpenPurchasesCommand}" Content="&#xE8B0;  Документы"/>
                    <Button Style="{StaticResource RibbonMenuButtonStyle}" Command="{Binding OpenPOSCommand}" Content="&#xE7BF;  Оплата"/>
                    <Button Style="{StaticResource RibbonMenuButtonStyle}" Command="{Binding OpenPlaceholderCommand}" CommandParameter="Склад" Content="&#xE8D1;  Склад"/>
                    <Button Style="{StaticResource RibbonMenuButtonStyle}" Command="{Binding OpenReportsCommand}" Content="&#xE9D9;  Отчеты"/>
                    <Button Style="{StaticResource RibbonMenuButtonStyle}" Command="{Binding OpenPlaceholderCommand}" CommandParameter="Анализ" Content="&#xE9D2;  Анализ"/>
                    <Button Style="{StaticResource RibbonMenuButtonStyle}" Command="{Binding OpenPlaceholderCommand}" CommandParameter="Маркетинг" Content="&#xE8D2;  Маркетинг"/>
                    <Button Style="{StaticResource RibbonMenuButtonStyle}" Command="{Binding OpenSettingsCommand}" Content="&#xE713;  Настройки"/>
                    <Button Style="{StaticResource RibbonMenuButtonStyle}" Command="{Binding OpenPlaceholderCommand}" CommandParameter="Помощь" Content="&#xE897;  Помощь"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,8,0,8">
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource QuickIconButtonStyle}" Command="{Binding OpenPOSCommand}" Content="&#xE7BF;" ToolTip="POS"/>
                <Button Style="{StaticResource QuickIconButtonStyle}" Command="{Binding OpenProductsCommand}" Content="&#xE14C;" ToolTip="Товары"/>
                <Button Style="{StaticResource QuickIconButtonStyle}" Command="{Binding OpenPurchasesCommand}" Content="&#xE8B0;" ToolTip="Закупки"/>
                <Button Style="{StaticResource QuickIconButtonStyle}" Command="{Binding OpenReportsCommand}" Content="&#xE9D9;" ToolTip="Отчеты"/>
                <Button Style="{StaticResource QuickIconButtonStyle}" Command="{Binding OpenSettingsCommand}" Content="&#xE713;" ToolTip="Настройки"/>
                <Separator Margin="10,0" Width="1"/>
                <TextBlock Text="{Binding CurrentUserInfo}" VerticalAlignment="Center" Foreground="#444"/>
                <Button Content="Войти" Command="{Binding LoginCommand}" Margin="14,0,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StatusCardStyle}">
                <StackPanel>
                    <TextBlock Text="Пользователь" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding UserName}"/>
                    <TextBlock Text="{Binding Role}" Foreground="#666"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource StatusCardStyle}">
                <StackPanel>
                    <TextBlock Text="Лицензия / Касса" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding LicenseInfo}"/>
                    <TextBlock Text="Касса #01" Foreground="#666"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource StatusCardStyle}">
                <StackPanel>
                    <TextBlock Text="Дата / БД" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding DateInfo}"/>
                    <TextBlock Text="{Binding DbInfo}" Foreground="#666"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource StatusCardStyle}">
                <StackPanel>
                    <TextBlock Text="Режим" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ModeInfo}"/>
                    <TextBlock Text="&lt;без ролевого доступу&gt;" Foreground="#666"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" VerticalAlignment="Top" Padding="16">
                <StackPanel>
                    <Border Width="56" Height="56" CornerRadius="28" Background="#E2E2E2" HorizontalAlignment="Left">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="30" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding UserName}" FontSize="16" FontWeight="Bold" Margin="0,10,0,2"/>
                    <TextBlock Text="{Binding Role}" Foreground="#666"/>
                    <TextBlock Text="&lt;без ролевого доступу&gt;" Foreground="#777" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHomeView}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="10" Padding="22" Margin="0,0,0,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFB347" Offset="0"/>
                            <GradientStop Color="#FF7A00" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <TextBlock Text="Ласкаво просимо до програми" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Text="SMOKETORG" Foreground="White" FontSize="42" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Style="{StaticResource LinkActionButtonStyle}" Command="{Binding OpenPurchasesCommand}" Content="&#xE72A;  Почати прихід товару"/>
                    <Button Style="{StaticResource LinkActionButtonStyle}" Command="{Binding OpenPOSCommand}" Content="&#xE72A;  Відкрити реалізацію"/>
                    <Button Style="{StaticResource LinkActionButtonStyle}" Command="{Binding OpenPlaceholderCommand}" CommandParameter="Склад" Content="&#xE72A;  Переглянути склад"/>
                </StackPanel>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="НОВИНИ" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding News}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F3F3F3" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="64"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="52" Height="52" Background="#FFE6CC" CornerRadius="6" VerticalAlignment="Top">
                                                <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" Foreground="#FF7A00" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}" Foreground="#777" FontSize="12"/>
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" Margin="0,2,0,4"/>
                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="#444"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <ContentControl Grid.Column="2" Content="{Binding CurrentViewModel}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHomeView}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>
    </Grid>
</Window>
