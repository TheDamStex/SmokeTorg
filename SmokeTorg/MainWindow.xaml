<Window x:Class="SmokeTorg.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SmokeTorg.Presentation.Views"
        xmlns:vm="clr-namespace:SmokeTorg.Presentation.ViewModels"
        Title="SmokeTorg" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="10">
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button Content="POS" Command="{Binding NavigateCommand}" CommandParameter="POS" Margin="0,0,8,0"/>
            <Button Content="Товары" Command="{Binding NavigateCommand}" CommandParameter="Products" Margin="0,0,8,0" Visibility="{Binding CanManageCatalog, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Button Content="Закупки" Command="{Binding NavigateCommand}" CommandParameter="Purchases" Margin="0,0,8,0" Visibility="{Binding CanManageCatalog, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Button Content="Склад" Command="{Binding NavigateCommand}" CommandParameter="Stock" Margin="0,0,8,0" Visibility="{Binding CanManageCatalog, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Button Content="Отчёты" Command="{Binding NavigateCommand}" CommandParameter="Reports" Margin="0,0,8,0" Visibility="{Binding CanManageCatalog, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Button Content="Настройки" Command="{Binding NavigateCommand}" CommandParameter="Settings" Margin="0,0,8,0" Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Button Content="Пользователи" Command="{Binding NavigateCommand}" CommandParameter="Users" Margin="0,0,8,0" Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <TextBlock Text="|" Margin="8,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding CurrentUserInfo}" VerticalAlignment="Center"/>
            <Button Content="Войти" Command="{Binding LoginCommand}" Margin="12,0,0,0"/>
        </StackPanel>

        <ContentControl Content="{Binding CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:PosViewModel}"><views:PosView/></DataTemplate>
                <DataTemplate DataType="{x:Type vm:ProductsViewModel}"><views:ProductsView/></DataTemplate>
                <DataTemplate DataType="{x:Type vm:PurchasesViewModel}"><views:PurchasesView/></DataTemplate>
                <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}"><views:PlaceholderView/></DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </DockPanel>
</Window>
